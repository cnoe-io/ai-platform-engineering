# ---------- Stage 1: Build dependencies ----------
FROM python:3.13-slim AS builder

ARG AGENT_NAME

RUN if [ -z "$AGENT_NAME" ]; then \
    echo "Error: AGENT_NAME build argument is required but not set."; \
    exit 1; \
    fi

# Install system dependencies and uv in one layer
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && pip install uv \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Mirror the source-tree layout under /app so that relative path sources in
# `[tool.uv.sources]` (e.g. `mcp-agent-auth = { path = "../../common/mcp-auth" }`)
# resolve inside the project base directory. uv refuses to follow `..` paths
# that escape the project root, so we cannot use a flat layout here.
COPY --chown=root:root ./ai_platform_engineering/agents/${AGENT_NAME}/mcp \
     /app/ai_platform_engineering/agents/${AGENT_NAME}/mcp/
COPY --chown=root:root ./ai_platform_engineering/agents/common \
     /app/ai_platform_engineering/agents/common/

WORKDIR /app/ai_platform_engineering/agents/${AGENT_NAME}/mcp

# Install dependencies into venv (no dev deps)
# Increase timeout for large packages (e.g., pyarrow 39MB)
RUN --mount=type=cache,target=/root/.cache/uv \
    UV_HTTP_TIMEOUT=300 uv sync --locked --no-dev

# ---------- Stage 2: Final runtime image ----------
# Wolfi (Chainguard) base: 0 CVEs, continuously patched packages, replaces
# python:3.13-slim to eliminate the ~300 Debian system-package CVEs per image.
FROM cgr.dev/chainguard/wolfi-base

ARG AGENT_NAME

RUN if [ -z "$AGENT_NAME" ]; then \
    echo "Error: AGENT_NAME build argument is required but not set."; \
    exit 1; \
    fi

# Override APK repo to public Wolfi OS packages (no auth required).
# cgr.dev/chainguard/wolfi-base defaults to apk.cgr.dev/chainguard which
# requires Chainguard credentials; packages.wolfi.dev/os is free and public.
ARG INSTALL_NETUTILS=false

RUN echo "https://packages.wolfi.dev/os" > /etc/apk/repositories && \
    for i in 1 2 3; do apk add --no-cache python-3.13 shadow && break; [ $i -lt 3 ] && sleep $((i * 10)); done && \
    if [ "$INSTALL_NETUTILS" = "true" ]; then \
        for i in 1 2 3; do \
            apk add --no-cache \
                bind-tools iputils whois curl iproute2 net-tools \
                dnsmasq mtr nmap net-snmp openssl tcpdump && break; \
            [ $i -lt 3 ] && sleep $((i * 10)); \
        done; \
    fi && \
    apk upgrade --no-cache

# The builder stage uses python:3.13-slim which places Python at
# /usr/local/bin/python3.13; Wolfi places it at /usr/bin/python3.13.
# These symlinks keep the venv's internal python symlinks from breaking.
RUN mkdir -p /usr/local/bin \
    && ln -sf /usr/bin/python3.13 /usr/local/bin/python3.13 \
    && ln -sf /usr/bin/python3.13 /usr/local/bin/python3 \
    && ln -sf /usr/bin/python3.13 /usr/local/bin/python

# Create appuser in final image
RUN groupadd -r appuser && useradd -r -g appuser -u 1001 -m appuser

# Mirror the layout used in the builder stage so the editable
# `mcp-agent-auth` install (whose .pth file points to ../../common/mcp-auth)
# still resolves at runtime. Pin WORKDIR + venv to the per-agent mcp dir.
ENV UV_PROJECT_ENVIRONMENT=/app/ai_platform_engineering/agents/${AGENT_NAME}/mcp/.venv \
    PATH="/app/ai_platform_engineering/agents/${AGENT_NAME}/mcp/.venv/bin:${PATH}" \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    AGENT_NAME=${AGENT_NAME}

WORKDIR /app/ai_platform_engineering/agents/${AGENT_NAME}/mcp

# Copy venv & code from builder (whole /app to preserve the agents/common/
# sibling directory referenced by the editable mcp-agent-auth package).
COPY --from=builder --chown=appuser:appuser /app /app

USER appuser

EXPOSE 8000

# Run the HTTP/SSE MCP server
CMD ["sh", "-c", "exec python -m mcp_${AGENT_NAME}"]