# CAIPE UI Dockerfile
# Multi-stage build for Next.js application with nginx reverse proxy
# Pattern based on RAG webui Dockerfile

# ---------- Stage 1: Install dependencies ----------
# Pin to BUILDPLATFORM so npm ci runs natively (avoids QEMU "Illegal instruction"
# crashes when cross-compiling arm64 on amd64 CI runners).
ARG BUILDPLATFORM
FROM --platform=$BUILDPLATFORM node:20-alpine AS deps
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Install dependencies with cache and network resilience
COPY ui/package.json ui/package-lock.json* ui/yarn.lock* ui/pnpm-lock.yaml* ./

# Configure npm for better network resilience
RUN npm config set fetch-retries 5 && \
    npm config set fetch-retry-mintimeout 20000 && \
    npm config set fetch-retry-maxtimeout 120000 && \
    npm config set fetch-timeout 300000

# Install dependencies with retry wrapper for transient registry errors (E403/ETIMEDOUT)
RUN set -e; \
    install_deps() { \
      if [ -f package-lock.json ]; then npm ci; \
      elif [ -f yarn.lock ]; then yarn install --frozen-lockfile; \
      elif [ -f pnpm-lock.yaml ]; then npm i -g pnpm && pnpm i --frozen-lockfile; \
      else npm i; fi; \
    }; \
    max_attempts=3; attempt=1; \
    until install_deps; do \
      if [ "$attempt" -ge "$max_attempts" ]; then \
        echo "npm install failed after $max_attempts attempts"; exit 1; \
      fi; \
      attempt=$((attempt + 1)); \
      echo "Attempt $((attempt - 1)) failed, retrying ($attempt/$max_attempts) in 15s..."; \
      sleep 15; \
      npm cache clean --force; \
    done

# ---------- Stage 2: Build application ----------
# Also pinned to BUILDPLATFORM — next build uses @next/swc at compile time only;
# the standalone output is platform-independent JavaScript.
FROM --platform=$BUILDPLATFORM node:20-alpine AS build
WORKDIR /app

# Build args for version info
ARG IMAGE_TAG=dev
ARG GIT_COMMIT=unknown
ARG BUILD_DATE

COPY --from=deps /app/node_modules ./node_modules
COPY ui .

# Disable telemetry during build
ENV NEXT_TELEMETRY_DISABLED=1

# Create version info file
RUN BUILD_DATE_VALUE="${BUILD_DATE}"; \
    if [ -z "$BUILD_DATE_VALUE" ]; then \
        BUILD_DATE_VALUE=$(date -u +%Y-%m-%dT%H:%M:%SZ); \
    fi; \
    printf '{"version":"%s","gitCommit":"%s","buildDate":"%s"}\n' \
    "${IMAGE_TAG}" \
    "${GIT_COMMIT}" \
    "$BUILD_DATE_VALUE" \
    > public/version.json && \
    cat public/version.json

# Build Next.js standalone application without baking in NEXT_PUBLIC_* vars
# These will be injected at runtime by entrypoint.sh (Layer 1) and
# PublicEnvScript server component (Layer 2)
RUN npm run build

# ---------- Stage 3: Production runtime ----------
FROM node:20-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Patch system packages to address CVEs
RUN apk update && apk upgrade --no-cache

# Create non-root user
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

# Copy built standalone application
# public/ must be chown'd so entrypoint.sh can write env-config.js at runtime
COPY --from=build --chown=nextjs:nodejs /app/public ./public
COPY --from=build --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=build --chown=nextjs:nodejs /app/.next/static ./.next/static

# Copy version info
COPY --from=build --chown=nextjs:nodejs /app/public/version.json ./public/version.json

# Copy entrypoint script
COPY --chown=nextjs:nodejs build/entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

USER nextjs

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# Runtime environment variables are injected via two layers:
# 1. entrypoint.sh generates /app/public/env-config.js at container start
# 2. Server component reads process.env at request time via API
# Both NEXT_PUBLIC_* and plain env vars are supported.
CMD ["/app/entrypoint.sh"]

# ---------- Stage 4: Development (hot reload) ----------
# Opt-in via `target: dev` in docker-compose (set CAIPE_UI_BUILD_TARGET=dev,
# typically by running `make dev-ui-hot` or exporting DEV_HOT_RELOAD=true and
# the wrapper in docker-compose.dev.yaml). Mounts ./ui/src and ./ui/public
# from the host so `next dev` picks up edits in <1s.
#
# Anonymous volumes for /app/node_modules and /app/.next must be declared in
# the compose file so the host bind doesn't shadow the container's installs.
FROM --platform=$BUILDPLATFORM node:20-alpine AS dev
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Reuse the dependency closure from the deps stage to avoid an extra `npm ci`.
COPY --from=deps /app/node_modules ./node_modules
COPY ui/package.json ui/package-lock.json* ./
# Copy the rest of the UI sources so first boot works even before any host
# bind-mount overlays them; the bind-mount then takes precedence on subsequent
# starts and on file edits.
COPY ui ./

ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1
# WATCHPACK_POLLING fallback: chokidar fs events sometimes drop through
# Docker Desktop's VirtioFS on macOS. Polling at 1s is cheap insurance.
ENV WATCHPACK_POLLING=true
ENV CHOKIDAR_USEPOLLING=true
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
EXPOSE 3000

CMD ["npm", "run", "dev"]
