# CAIPE UI Environment Configuration
# Copy this file to .env.local and configure as needed

# ===========================================
# CAIPE Backend Configuration
# ===========================================

# CAIPE A2A endpoint URL
# For local development: http://localhost:8000
# For Docker: http://caipe-supervisor:8000
NEXT_PUBLIC_CAIPE_URL=http://localhost:8000

# RAG Server URL for knowledge base operations
# For local development: http://localhost:9446
# For Docker: http://rag-server:9446
NEXT_PUBLIC_RAG_URL=http://localhost:9446

# ===========================================
# SSO / OIDC Configuration (Optional)
# ===========================================

# Enable SSO authentication
# Set to "true" to enable OIDC authentication, otherwise leave empty or "false"
NEXT_PUBLIC_SSO_ENABLED=false

# NextAuth.js Configuration
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# Base URL for NextAuth callbacks
# For local development: http://localhost:3000
# For production: https://your-domain.com
NEXTAUTH_URL=http://localhost:3000

# OIDC Provider Configuration
# These are server-side only (not exposed to browser)
OIDC_ISSUER=https://your-oidc-provider.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
# Comma-separated list of accepted JWT audience values (in addition to OIDC_CLIENT_ID)
# Useful when the OIDC authorization server mints tokens with a different audience than the client ID
# OIDC_ACCEPTED_AUDIENCES=https://my-api.example.com,urn:my-resource

# ===========================================
# Authorization / Group-Based Access Control
# ===========================================

# OIDC claim name(s) containing user groups
# Supports single value or comma-separated list:
#   Single: memberOf
#   Multiple: groups,members,roles (all checked, results combined and deduplicated)
# Common values: memberOf, groups, members, group, roles, cognito:groups
# Leave empty to auto-detect from common claim names
OIDC_GROUP_CLAIM=memberOf

# Required group for access (checked against the group claim)
# Users must be a member of this group to access the application
# Leave empty to disable group-based authorization
OIDC_REQUIRED_GROUP=app-users

# Admin group for elevated privileges
# Users in this group will have admin role and access to admin dashboard
# Leave empty to disable admin group checking (all users will be 'user' role)
OIDC_REQUIRED_ADMIN_GROUP=app-admins

# Admin view group for read-only admin dashboard access
# Users in this group can view admin stats, users, teams, and metrics
# but cannot make changes (role updates, team CRUD, migrations)
# Leave empty to allow all authenticated users to view admin dashboard
OIDC_REQUIRED_ADMIN_VIEW_GROUP=app-users

# Support contact email for access requests and help
# Displayed on unauthorized page and error screens
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com

# ===========================================
# OIDC Callback URLs to Configure
# ===========================================
#
# When setting up your OIDC provider, add these callback URLs:
#
# For localhost development:
#   http://localhost:3000/api/auth/callback/oidc
#
# For production:
#   https://your-domain.com/api/auth/callback/oidc
#
# ===========================================
# Storage Configuration - MongoDB vs localStorage (EXCLUSIVE)
# ===========================================
#
# IMPORTANT: The app uses ONLY ONE storage mode (not hybrid)
# - MongoDB mode: Persistent, shareable, team collaboration
# - localStorage mode: Browser-only, not shareable
#
# Set MONGODB_URI to enable MongoDB mode
# Leave unset for localStorage mode
# CAIPE UI supports TWO storage modes with automatic fallback:
#
# 1. MongoDB Mode (Recommended for Production)
#    - Persistent storage across devices
#    - Sharing and collaboration features
#    - Server-side search
#    - Set MONGODB_URI and MONGODB_DATABASE below
#
# 2. localStorage Mode (Fallback)
#    - Local browser storage only
#    - No setup required
#    - Great for development and demos
#    - Automatically used if MongoDB not configured
#
# The app automatically detects which mode to use and gracefully
# falls back to localStorage if MongoDB is unavailable.
#

# MongoDB connection string (optional - enables MongoDB mode)
# If not set, app runs in localStorage-only mode
# Example: mongodb://localhost:27017
# Example with auth: mongodb://username:password@localhost:27017?authSource=admin
MONGODB_URI=mongodb://admin:changeme@localhost:27017

# MongoDB database name (required if MONGODB_URI is set)
MONGODB_DATABASE=caipe

# Client-side flag to enable MongoDB mode (required!)
# Set to "true" when MONGODB_URI is configured
# This allows client-side code to detect MongoDB mode without exposing the URI
NEXT_PUBLIC_MONGODB_ENABLED=true

# ===========================================
# Use Case Storage Configuration
# ===========================================
#
# Storage type for use cases (default: "file")
# Options: "file" or "mongodb"
USECASE_STORAGE_TYPE=file

# File-based storage path (only used when USECASE_STORAGE_TYPE=file)
# Default: ./data/usecases.json
# USECASE_STORAGE_PATH=./data/usecases.json

# ===========================================
# Branding / Customization (Optional)
# ===========================================
#
# Customize the tagline and description shown throughout the UI.
# These appear on login, logout, loading screens, and chat welcome.
#

# Main tagline (default: "Multi-Agent Collaboration & Workflow Automation")
NEXT_PUBLIC_TAGLINE=Multi-Agent Collaboration & Workflow Automation

# Description text (default: "AI agents and native apps collaborating across tools and teams to get work done.")
NEXT_PUBLIC_DESCRIPTION=AI agents and native apps collaborating across tools and teams to get work done.

# Application name (default: "CAIPE")
NEXT_PUBLIC_APP_NAME=CAIPE

# Logo URL (default: "/logo.svg")
# Can be a relative path (e.g., "/custom-logo.svg") or absolute URL (e.g., "https://example.com/logo.png")
NEXT_PUBLIC_LOGO_URL=/logo.svg

# Environment badge (default: empty = hidden)
# Set to a label like "Dev", "Preview", "Staging", or "Prod" to show a badge next to the app name.
# Leave empty or unset to hide the badge entirely.
# Backward-compat: NEXT_PUBLIC_PREVIEW_MODE=true still works (shows "Preview").
NEXT_PUBLIC_ENV_BADGE=

# Workflow runner (default: false)
# Enable the dedicated "Run Workflow" button in the Skills modal and the
# Multi-Step Workflows card section.  When false, users can only "Run in Chat".
WORKFLOW_RUNNER_ENABLED=false

# ===========================================
# Built-in Skill Mutation Lock
# ===========================================
# When false (default), `agent_skills` rows with `is_system: true`
# (seeded built-in templates) are READ-ONLY for all users:
#   - PUT /api/skills/configs?id=<built-in-id>          → 403
#   - DELETE /api/skills/configs?id=<built-in-id>       → 403
#   - PUT /api/skills/configs/[id]/files                → 403
#   - DELETE /api/skills/configs/[id]/files             → 403
# Admins can still scan built-ins and clone them via the gallery's
# "Clone" action (POST /api/skills/configs/[id]/clone) to produce
# an editable user-owned copy.
#
# Set to `true` to restore the legacy behaviour where any
# authenticated user could edit / delete built-in rows directly.
# Internal seed/import paths (POST /api/skills/seed,
# /api/skills/templates/import) are unaffected by this flag.
# ALLOW_BUILTIN_SKILL_MUTATION=false

# ===========================================
# Skills Builder — AI generate / enhance (dynamic-agents)
# ===========================================
#
# Server-side only: Next.js API routes call dynamic-agents POST /api/v1/assistant/suggest.
# Must match the host:port where dynamic-agents actually listens (ECONNREFUSED = wrong URL or service down).
# Default if unset: http://localhost:8100
#
# DYNAMIC_AGENTS_URL=http://localhost:8100
#
# Optional model overrides for /api/skills/generate (see route.ts for defaults).
# SKILL_AI_MODEL_ID=bedrock/global.anthropic.claude-haiku-4-5-20251001-v1:0
# SKILL_AI_MODEL_PROVIDER=openai

# ===========================================
# Header Link Configuration (Optional)
# ===========================================
#
# Control the documentation and source code links in the header.
# Leave empty/commented to hide these links.

# Documentation URL - shows a book icon linking to docs
# DOCS_URL=https://your-docs-site.com

# Source code URL - shows a GitHub icon linking to source
# SOURCE_URL=https://github.com/your-org/your-repo

# ===========================================
# Theme / Gradient Customization (Optional)
# ===========================================
#
# Customize the primary gradient colors used throughout the UI.
# Colors should be in HSL format: "hsl(hue, saturation%, lightness%)"
# or any valid CSS color value (hex, rgb, etc.)
#

# Gradient start color (default: "hsl(173,80%,40%)" - teal)
NEXT_PUBLIC_GRADIENT_FROM=hsl(173,80%,40%)

# Gradient end color (default: "hsl(270,75%,60%)" - purple)
NEXT_PUBLIC_GRADIENT_TO=hsl(270,75%,60%)

# Logo style: "default" (original colors) or "white" (inverted to white)
# Use "white" when your logo needs to appear on gradient backgrounds
# Use "default" when your logo already has the right colors for the background
NEXT_PUBLIC_LOGO_STYLE=default

# Spinner/loading indicator color (default: uses primary theme color)
# Can be any valid CSS color (hex, hsl, rgb, etc.)
# NEXT_PUBLIC_SPINNER_COLOR=#00bcd4

# Show "Powered by OSS caipe.io" footer (default: true)
# Set to "false" to hide the footer on login, logout, and loading screens
NEXT_PUBLIC_SHOW_POWERED_BY=true

# ===========================================
# Langfuse User Feedback Configuration (Optional)
# ===========================================
#
# Langfuse is used for tracking user feedback on AI responses.
# When configured, thumbs up/down feedback is sent to Langfuse
# as scores linked to traces for quality analysis.
#
# The feedback is sent server-side to keep the secret key secure.
#
# See: https://langfuse.com/docs/observability/features/user-feedback
#

# Langfuse public key (required for feedback tracking)
# Get this from your Langfuse project settings
# LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx

# Langfuse secret key (required for feedback tracking, server-side only)
# Get this from your Langfuse project settings
# LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx

# Langfuse host URL (required for feedback tracking)
# For cloud: https://cloud.langfuse.com
# For self-hosted: http://langfuse-web:3000 or your custom URL
# LANGFUSE_HOST=https://cloud.langfuse.com

# ===========================================
# Skills middleware / skill-scanner (supervisor + CI; operator reference)
# ===========================================
#
# Max skill summaries injected into supervisor system prompt (Python supervisor env).
# 0 or unset = no cap (all merged skills). FR-024.
# MAX_SKILL_SUMMARIES_IN_PROMPT=100
#
# JWT claim holding team / group ids for catalog entitlement (FR-020). Python router.
# OIDC_TEAMS_CLAIM=groups
#
# Catalog API key auth: header name and HMAC pepper for stored key hashes (Python).
# CAIPE_CATALOG_API_KEY_HEADER=X-Caipe-Catalog-Key
# CAIPE_CATALOG_API_KEY_PEPPER=change-me-in-production
#
# MongoDB collection catalog_api_keys: key_id, key_hash, owner_user_id, scopes, revoked_at
#
# Packaged skills scan (scripts/scan-packaged-skills.sh): directory of SKILL.md trees.
# SKILLS_DIR=/path/to/bundled/skills
#
# Scanner gate: strict (default) excludes flagged + unscanned skills from the
# supervisor catalog and dynamic agents; warn surfaces warnings but only blocks
# explicitly flagged skills; off disables severity-based gating entirely.
# Note: scan_status="flagged" is ALWAYS blocked regardless of this setting.
# SKILL_SCANNER_GATE=strict
# SKILL_SCANNER_POLICY=balanced
# SKILL_SCANNER_FAIL_ON=high
#
# URL of the standalone skill-scanner API server. The UI
# uploads zipped SKILL packages here for safety scanning. Bring it up via:
#   docker compose --profile skill-scanner up -d
# (or `--profile caipe-ui`, which transitively starts the scanner).
# Helm: enable `global.skillScanner.enabled=true` in the parent chart.
SKILL_SCANNER_URL=http://localhost:8765

# ===========================================
# Agentic Apps Platform (Optional)
# ===========================================
#
# Comma-separated admin-installed app IDs exposed through the CAIPE host.
# Sample external apps:
#   npm run agentic-apps:finops
#   npm run agentic-apps:weather
#
# The host mounts enabled apps under /apps/<id> and proxies allowed requests to
# the configured app origin with CAIPE-issued app-scoped tokens. Do not place
# provider/root tokens in manifests or browser-visible config.
#
# Top-level server-only host install toggle. When false/unset, /apps, app APIs,
# and app proxy execution stay hidden/404 even if individual app IDs are
# configured. Do not use NEXT_PUBLIC_ for this flag.
# AGENTIC_APPS_INSTALL_ENABLED=true
#
# Comma-separated built-in/sample app IDs to expose after the install toggle is on.
# AGENTIC_APPS_ENABLED=agentic-sdlc,finops,weather,oss-repo-management,jira-project-dashboard
#
# Per-app host overrides follow a uniform pattern keyed on the app id, with
# hyphens converted to underscores and uppercased:
#
#   AGENTIC_APP_<UPPER_ID>_ORIGIN       upstream origin (http(s)://host:port)
#   AGENTIC_APP_<UPPER_ID>_MOUNT_PATH   public mount path (must stay under /apps/)
#   AGENTIC_APP_<UPPER_ID>_DISABLED     force-disable without editing AGENTIC_APPS_ENABLED
#
# Examples for the built-in samples:
# AGENTIC_APP_FINOPS_ORIGIN=http://localhost:3010
# AGENTIC_APP_FINOPS_MOUNT_PATH=/apps/finops
# AGENTIC_APP_WEATHER_ORIGIN=http://localhost:3020
# AGENTIC_APP_WEATHER_MOUNT_PATH=/apps/weather
# AGENTIC_APP_OSS_REPO_MANAGEMENT_ORIGIN=http://localhost:3040
# AGENTIC_APP_OSS_REPO_MANAGEMENT_MOUNT_PATH=/apps/oss-repo-management
# AGENTIC_APP_JIRA_PROJECT_DASHBOARD_ORIGIN=http://localhost:3041
# AGENTIC_APP_JIRA_PROJECT_DASHBOARD_MOUNT_PATH=/apps/jira-project-dashboard
# AGENTIC_APP_AGENTIC_SDLC_ORIGIN=http://localhost:3030
# AGENTIC_APP_AGENTIC_SDLC_MOUNT_PATH=/apps/agentic-sdlc
#
# Operators install additional apps (internal or third-party) by seeding the
# marketplace package collection in MongoDB, listing the app id in
# AGENTIC_APPS_ENABLED, and setting the matching AGENTIC_APP_<ID>_* vars
# above. No source-code change is required to add a new app.
#
# Trust contract: CAIPE app-scoped token verification per app id.
#
# The host gateway forwards a short-lived app-scoped HS256 JWT as
# `Authorization: Bearer <jwt>` to allowed proxied and webhook requests, plus
# non-authoritative delivery hints:
#
#   x-caipe-app-id, x-caipe-decision-id, x-correlation-id
#
# Each app verifies the JWT signature, issuer, audience, app id, scopes, and
# expiry before serving protected resources.
#
# Server-side signing secret. Defaults to NEXTAUTH_SECRET when unset; set a
# dedicated secret in production.
# AGENTIC_APP_TOKEN_SECRET=
# AGENTIC_APP_TOKEN_ISSUER=caipe-agentic-apps
#
# Optional per-app audience overrides. Defaults to `agentic-app:<id>`.
# AGENTIC_APP_FINOPS_JWT_AUDIENCE=
# AGENTIC_APP_WEATHER_JWT_AUDIENCE=
# AGENTIC_APP_OSS_REPO_MANAGEMENT_JWT_AUDIENCE=
# AGENTIC_APP_JIRA_PROJECT_DASHBOARD_JWT_AUDIENCE=
# AGENTIC_APP_AGENTIC_SDLC_JWT_AUDIENCE=
#
# Webhook and health policy knobs:
# AGENTIC_APP_WEBHOOK_MAX_BODY_BYTES=10485760
# AGENTIC_APP_HEALTH_DEFAULT_TIMEOUT_MS=2000

# ===========================================
# Agentic SDLC (Optional, default disabled)
# ===========================================
#
# Agentic SDLC is delivered as an in-process Agentic App mounted at
# `/apps/agentic-sdlc`. Visibility is gated by:
#   1. SHIP_LOOP_ENABLED (this env var) — server-wide kill switch. When
#      false (default), `/api/agentic-sdlc/**` returns 404, the
#      `/apps/agentic-sdlc` route returns 404, and the app's manifest is
#      hidden from the Agentic Apps registry.
#   2. The standard Agentic Apps install/enabled gates
#      (AGENTIC_APPS_INSTALL_ENABLED=true and AGENTIC_APPS_ENABLED including
#      `agentic-sdlc` or `*`).
#   3. Per-app RBAC from the manifest (`access.requiredRoles`, default
#      `user`; `admin` implicitly inherits `user`).
#
# The retired per-user `shipLoop` feature flag is no longer consulted.
#
# Spec: docs/docs/specs/2026-05-05-agentic-sdlc-ship-loop-ui/spec.md
SHIP_LOOP_ENABLED=false

# Independent sub-toggle for the "Talk to the loop" AG-UI assistant side
# panel. When false (default), the dashboard ships but the assistant panel
# is hidden. Has no effect when SHIP_LOOP_ENABLED=false.
SHIP_LOOP_ASSISTANT_ENABLED=false

# Shared HMAC secret for verifying GitHub webhook deliveries. The webhook
# receiver rejects any delivery with an invalid X-Hub-Signature-256.
# Per-repo overrides can be added later via the OnboardedRepo record.
# Generate with: openssl rand -hex 32
# GITHUB_WEBHOOK_SECRET=

# Comma-separated GitHub login names (case-insensitive) treated as
# "agent" actors when classifying PRs/comments as agent-vs-human.
# Default: caipe-bot,renovate[bot],dependabot[bot]
# SHIP_LOOP_AGENT_BOT_LOGINS=caipe-bot,renovate[bot],dependabot[bot]

# ID of the preconfigured CAIPE Dynamic Agent that backs the
# "Talk to the loop" side panel (Clarification Q1). Required when
# SHIP_LOOP_ASSISTANT_ENABLED=true.
# SHIP_LOOP_ASSISTANT_AGENT_ID=ship-loop-assistant

# -------------------------------------------------------------------------
# GitHub Webhook Receiver (integrations/github-webhook-receiver)
# -------------------------------------------------------------------------
# Long-running SQS poller (docker-compose service `github-webhook-receiver`)
# that forwards GitHub webhook deliveries from the
# `github-webhook-sqs` SQS queue to the Agentic SDLC route on caipe-ui.
#
# Profile gating: the receiver only starts when one of the
# `agentic-sdlc`, `github-webhook`, or `caipe-ui` compose profiles is
# active.
#
# --- AWS credentials selection ---
#
# The SQS queue `github-webhook-sqs` lives in account 626007623524 (us-east-2).
# CAIPE's shared .env credentials (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY)
# usually belong to a *different* account (the `caipe-aws-agent-creds` IAM
# user in account 471112537430), so the receiver does an STS assume-role
# hop into the queue-owning account on startup, matching the receiver's
# local development flow.
#
# Defaults are pre-wired for the canonical setup:
#
#   * Base identity  = whatever AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY are
#                      in this file (the shared Bedrock keys).
#   * Assume role    = arn:aws:iam::626007623524:role/caipe-local-github-webhook-sqs-reader
#   * External ID    = caipe-local-github-webhook-forwarder
#   * Session name   = caipe-github-webhook-receiver
#
# You normally do NOT need to override anything below; uncomment a line
# only when your environment diverges from the canonical CAIPE setup
# (e.g. dedicated IAM user, different role ARN, no assume-role at all).
#
# To disable the assume-role hop entirely (e.g. you minted an IAM user
# that has direct SQS access), set GITHUB_WEBHOOK_AWS_ASSUME_ROLE_ARN to
# an empty string.

# Override the queue's region if it ever moves. Defaults to us-east-2.
# GITHUB_WEBHOOK_AWS_REGION=us-east-2

# Override the assume-role target if your environment uses a different role.
# Empty string = skip assume-role and use base creds directly.
# GITHUB_WEBHOOK_AWS_ASSUME_ROLE_ARN=arn:aws:iam::626007623524:role/caipe-local-github-webhook-sqs-reader
# GITHUB_WEBHOOK_AWS_ASSUME_ROLE_EXTERNAL_ID=caipe-local-github-webhook-forwarder
# GITHUB_WEBHOOK_AWS_ASSUME_ROLE_SESSION_NAME=caipe-github-webhook-receiver
# GITHUB_WEBHOOK_AWS_ASSUME_ROLE_DURATION_SECONDS=3600

# Override the BASE credentials (the principal that calls AssumeRole).
# Leave unset to fall back to the shared AWS_ACCESS_KEY_ID/_SECRET above.
# GITHUB_WEBHOOK_AWS_ACCESS_KEY_ID=
# GITHUB_WEBHOOK_AWS_SECRET_ACCESS_KEY=
# GITHUB_WEBHOOK_AWS_SESSION_TOKEN=

# SQS queue name (region pulled from GITHUB_WEBHOOK_AWS_REGION above).
# GITHUB_WEBHOOK_SQS_QUEUE=github-webhook-sqs

# Where the receiver POSTs forwarded webhooks. Inside the compose network
# this is the caipe-ui container; override for tests that point at the
# host-mode Next.js dev server.
# GITHUB_WEBHOOK_FORWARD_URL=http://caipe-ui:3000/api/agentic-sdlc/webhooks/github

# Tuning: SQS long-poll batch + wait, plus outbound POST timeout.
# GITHUB_WEBHOOK_BATCH_SIZE=10
# GITHUB_WEBHOOK_WAIT_SECONDS=20
# GITHUB_WEBHOOK_REQUEST_TIMEOUT=15

# Verbosity. Set GITHUB_WEBHOOK_LOG_PAYLOAD=1 to log full webhook bodies
# (chatty; useful only for debugging unfamiliar event shapes).
# GITHUB_WEBHOOK_LOG_LEVEL=INFO
# GITHUB_WEBHOOK_LOG_PAYLOAD=0

# ===========================================
