{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@platform/*": ["src/platform/*"],
      "@auth/*": ["src/auth/*"],
      "@chat/*": ["src/chat/*"],
      "@skills/*": ["src/skills/*"],
      "@agents/*": ["src/agents/*"],
      "@memory/*": ["src/memory/*"],
      "@commit/*": ["src/commit/*"],
      "@headless/*": ["src/headless/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist"]
}
