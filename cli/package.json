{
  "name": "caipe",
  "version": "0.1.0",
  "description": "AI-assisted coding, workflows, and platform engineering from the terminal",
  "bin": {
    "caipe": "./dist/shim.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "compile:darwin-arm64": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile dist/caipe-darwin-arm64",
    "compile:darwin-x64": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile dist/caipe-darwin-x64",
    "compile:linux-arm64": "bun build src/index.ts --compile --target=bun-linux-arm64 --outfile dist/caipe-linux-arm64",
    "compile:linux-x64": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile dist/caipe-linux-x64",
    "compile:all": "bun run compile:darwin-arm64 && bun run compile:darwin-x64 && bun run compile:linux-arm64 && bun run compile:linux-x64",
    "dev": "bun run src/index.ts",
    "test": "bun test tests/",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "format": "biome format --write src/ tests/"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.52",
    "react-devtools-core": "file:./src/stubs/react-devtools-core",
    "commander": "^12.1.0",
    "diff": "^7.0.0",
    "execa": "^9.5.2",
    "ink": "^5.1.0",
    "keytar": "^7.9.0",
    "marked": "^12.0.0",
    "marked-terminal": "^7.1.0",
    "react": "^18.3.0",
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "1.3.12",
    "@types/diff": "^6.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/semver": "^7.5.8",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.1"
  },
  "keywords": ["caipe", "ai", "cli", "platform-engineering"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cnoe-io/ai-platform-engineering"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ],
  "overrides": {
    "react-devtools-core": "file:./src/stubs/react-devtools-core"
  }
}
