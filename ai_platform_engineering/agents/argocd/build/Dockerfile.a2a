FROM python:3.13-slim

WORKDIR /app

# Copy cnoe-agent-utils package
COPY cnoe-agent-utils /cnoe-agent-utils

# Copy the agent code
COPY ai_platform_engineering/agents/argocd /app/

# Install uv and use it to install the package
RUN pip install uv poetry

RUN poetry config virtualenvs.create false
RUN poetry config virtualenvs.in-project false
RUN poetry config cache-dir /app/.cache

# Update pyproject.toml to use the correct path for cnoe-agent-utils
RUN sed -i 's|"../../../cnoe-agent-utils"|"/cnoe-agent-utils"|' pyproject.toml

RUN poetry add /app/mcp/argocd

# Update lock file and install
RUN poetry lock
RUN poetry install --no-interaction

EXPOSE 8000

CMD ["poetry", "--quiet", "run", "python", "-m", "agent_argocd", "--host", "0.0.0.0", "--port", "8000"]