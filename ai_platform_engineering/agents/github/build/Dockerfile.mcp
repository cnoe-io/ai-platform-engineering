# ---------- Stage 1: Build Go binary ----------
FROM golang:1.26-alpine AS builder

RUN apk add --no-cache git

WORKDIR /build
COPY ./ai_platform_engineering/mcp/mcp_github/ .

RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" \
    -o /github-mcp-server ./cmd/github-mcp-server

# ---------- Stage 2: Minimal runtime ----------
# Wolfi (Chainguard) base: 0 CVEs, continuously patched packages.
FROM cgr.dev/chainguard/wolfi-base

# Override APK repo to public Wolfi OS packages (no auth required).
RUN echo "https://packages.wolfi.dev/os" > /etc/apk/repositories && \
    apk add --no-cache ca-certificates wget shadow && \
    groupadd -r appuser && useradd -r -g appuser -u 1001 -m appuser

COPY --from=builder /github-mcp-server /github-mcp-server

USER appuser

EXPOSE 8000

ENTRYPOINT ["/github-mcp-server", "http", "--port", "8000"]
