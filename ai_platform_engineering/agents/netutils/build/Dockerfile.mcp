# ---------- Stage 1: Build dependencies ----------
FROM python:3.13-slim AS builder

ARG AGENT_NAME=netutils

RUN if [ -z "$AGENT_NAME" ]; then \
    echo "Error: AGENT_NAME build argument is required but not set."; \
    exit 1; \
    fi

# Install system dependencies and uv in one layer
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && pip install uv \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --chown=root:root ./ai_platform_engineering/agents/${AGENT_NAME}/mcp ./

# Install dependencies into venv (no dev deps)
RUN --mount=type=cache,target=/root/.cache/uv \
    UV_HTTP_TIMEOUT=300 uv sync --locked --no-dev

# ---------- Stage 2: Final runtime image ----------
FROM python:3.13-slim

ARG AGENT_NAME=netutils

RUN if [ -z "$AGENT_NAME" ]; then \
    echo "Error: AGENT_NAME build argument is required but not set."; \
    exit 1; \
    fi

# Install network diagnostic and Cisco-centric tools required by MCP tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    dnsutils \
    iputils-ping \
    traceroute \
    whois \
    curl \
    iproute2 \
    net-tools \
    dnsmasq \
    mtr-tiny \
    nmap \
    snmp \
    lldpd \
    openssl \
    tcpdump \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Create appuser in final image
RUN groupadd -r appuser && useradd -r -g appuser -u 1001 -m appuser

WORKDIR /app

ENV UV_PROJECT_ENVIRONMENT=/app/.venv \
    PATH="/app/.venv/bin:${PATH}" \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    AGENT_NAME=${AGENT_NAME}

# Copy venv & code from builder
COPY --from=builder --chown=appuser:appuser /app /app

USER appuser

EXPOSE 8000

CMD ["sh", "-c", "exec python -m mcp_${AGENT_NAME}"]
