{
  "annotations": {
    "title": "Create repository"
  },
  "description": "Create a new GitHub repository in your account or specified organization. Optionally create from a template repository by providing template_owner and template_repo.",
  "inputSchema": {
    "properties": {
      "autoInit": {
        "description": "Initialize with README (ignored when using a template)",
        "type": "boolean"
      },
      "description": {
        "description": "Repository description",
        "type": "string"
      },
      "name": {
        "description": "Repository name",
        "type": "string"
      },
      "organization": {
        "description": "Organization to create the repository in (omit to create in your personal account)",
        "type": "string"
      },
      "private": {
        "description": "Whether repo should be private",
        "type": "boolean"
      },
      "template_owner": {
        "description": "Owner of the template repository to create from (requires template_repo)",
        "type": "string"
      },
      "template_repo": {
        "description": "Name of the template repository to create from (requires template_owner)",
        "type": "string"
      }
    },
    "required": [
      "name"
    ],
    "type": "object"
  },
  "name": "create_repository"
}