# CAIPE UI — Tome dev instance environment
# Copy this file to ui/.env.local and fill in your secrets.
# This file is safe to commit — no real credentials here.

# ============================================
# A2A Configuration
# ============================================
NEXT_PUBLIC_A2A_BASE_URL=http://localhost:8000

# ============================================
# Feature Flags
# ============================================
NEXT_PUBLIC_SSO_ENABLED=true
NEXT_PUBLIC_ENABLE_SUBAGENT_CARDS=true
AUDIT_LOGS_ENABLED=true
WORKFLOW_RUNNER_ENABLED=true
FEEDBACK_ENABLED=true
NPS_ENABLED=true
DYNAMIC_AGENTS_ENABLED=true
DYNAMIC_AGENTS_URL=http://localhost:18100

# ============================================
# Tome / Projects / Agentic Apps
# ============================================
AGENTIC_APP_FINOPS_ORIGIN=http://localhost:3010
AGENTIC_APP_WEATHER_ORIGIN=http://localhost:3020
AGENTIC_APP_JIRA_PROJECT_DASHBOARD_ORIGIN=http://localhost:3041
AGENTIC_APP_OSS_REPO_MANAGEMENT_ORIGIN=http://localhost:3040
AGENTIC_APPS_INSTALL_ENABLED=true
# Enable all built-in apps; restrict with comma-separated IDs if needed
AGENTIC_APPS_ENABLED=*
SHIP_LOOP_ENABLED=true
SHIP_LOOP_ASSISTANT_ENABLED=true
TOME_ENABLED=true
TOME_AGENT_URL=http://localhost:9500
WORKFLOWS_ENABLED=true

# ============================================
# NextAuth Configuration
# ============================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:33000

# ============================================
# OIDC/SSO — local Keycloak (docker-compose.tome.yaml)
# ============================================
OIDC_ISSUER=http://localhost:17080/realms/caipe
OIDC_CLIENT_ID=caipe-ui
OIDC_CLIENT_SECRET=caipe-ui-dev-secret
OIDC_REQUIRED_GROUP=
OIDC_REQUIRED_ADMIN_GROUP=
OIDC_ENABLE_REFRESH_TOKEN=true
OIDC_IDP_HINT=
BOOTSTRAP_ADMIN_EMAILS=your-email@example.com

# ============================================
# Credentials / Connections
# ============================================
CAIPE_CREDENTIALS_ENABLED=true
CAIPE_USER_CONNECTIONS_ENABLED=true
CREDENTIAL_STORE_BACKEND=mongodb-envelope
CREDENTIAL_KEY_PROVIDER=local-cmk
CREDENTIAL_ALLOW_INSECURE_LOCAL_KEY_WRAP=true
CREDENTIAL_BOOTSTRAP_OAUTH_CONNECTORS=true

# GitHub OAuth app — must have http://localhost:33000/api/credentials/oauth/github/callback registered
GITHUB_CLIENT_ID=replace-me
GITHUB_CLIENT_SECRET=replace-me
GITHUB_REDIRECT_URI=http://localhost:33000/api/credentials/oauth/github/callback

# Confluence OAuth app (optional)
CONFLUENCE_CLIENT_ID=replace-me
CONFLUENCE_CLIENT_SECRET=replace-me
CONFLUENCE_REDIRECT_URI=http://localhost:33000/api/credentials/oauth/atlassian/callback

# GitLab OAuth app (optional)
GITLAB_CLIENT_ID=replace-me
GITLAB_CLIENT_SECRET=replace-me
GITLAB_REDIRECT_URI=http://localhost:33000/api/credentials/oauth/gitlab/callback

# Webex OAuth app (optional)
WEBEX_CLIENT_ID=replace-me
WEBEX_CLIENT_SECRET=replace-me
WEBEX_REDIRECT_URI=http://localhost:33000/api/credentials/oauth/webex/callback

# PagerDuty OAuth app (optional)
PAGERDUTY_CLIENT_ID=replace-me
PAGERDUTY_CLIENT_SECRET=replace-me
PAGERDUTY_REDIRECT_URI=http://localhost:33000/api/credentials/oauth/pagerduty/callback

# ============================================
# Keycloak Admin API
# ============================================
KEYCLOAK_URL=http://localhost:17080

# ============================================
# OpenFGA (tome stack — port 28080)
# ============================================
OPENFGA_HTTP=http://localhost:28080
OPENFGA_STORE_NAME=caipe-openfga
KEYCLOAK_REALM=caipe

# ============================================
# Storage — dedicated MongoDB for tome (port 27117)
# ============================================
MONGODB_URI=mongodb://admin:changeme@localhost:27117/caipe?authSource=admin
MONGODB_DATABASE=caipe

# ============================================
# RAG Configuration (optional)
# ============================================
RAG_ENABLED=true
RAG_SERVER_URL=http://localhost:9446
RAG_SERVER_MCP_URL=http://localhost:9446/mcp

# ============================================
# Local MCP Servers (optional)
# ============================================
GITHUB_MCP_URL=http://localhost:8082
ARGOCD_MCP_URL=http://localhost:18002/mcp
JIRA_MCP_URL=http://localhost:18004/mcp
PAGERDUTY_MCP_URL=http://localhost:18006/mcp

# ============================================
# Observability (optional)
# ============================================
PROMETHEUS_URL=http://localhost:9090

# ============================================
# UI Customization
# ============================================
APP_NAME=Grid
TAGLINE=Human x AI Agent Collaboration
DESCRIPTION=Where Humans and AI agents collaborate to deliver high quality outcomes.
LOGO_URL=/grid-neon-logo.svg
LOGO_STYLE=white
SPINNER_COLOR=#00bcd4
SHOW_POWERED_BY=true
ENV_BADGE=Preview

# ============================================
# Skills Backend
# ============================================
BACKEND_SKILLS_URL=http://localhost:8000

# GitHub personal access token for Skill Hubs
GITHUB_TOKEN=replace-me

# ============================================
# Projects Onboarding Config (local overlay)
# ============================================
PROJECTS_ONBOARDING_CONFIG_PATH=../config/projects-onboarding.local.yaml

# ============================================
# Seed Configuration
# ============================================
SEED_CONFIG_PATH=../ai_platform_engineering/dynamic_agents/src/dynamic_agents/services/config.yaml
