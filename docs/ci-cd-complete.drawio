        <mxCell id="ghcr" value="&lt;b&gt;GHCR (ghcr.io/cnoe-io/)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;&lt;br&gt;-dev.N or final (x.y.z) → ghcr.io/cnoe-io/&amp;lt;image&amp;gt;:tag&lt;br&gt;-rc.N or -hotfix.N → ghcr.io/cnoe-io/&lt;b&gt;pre-release&lt;/b&gt;/&amp;lt;image&amp;gt;:tag&lt;br&gt;&lt;br&gt;image_prefix decided in determine-changes job:&lt;br&gt;  tag matches -(rc|hotfix)\\.  → prefix = &quot;pre-release/&quot;&lt;br&gt;  else → prefix = &quot;&quot;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontFamily=SFMono-Regular;fontSize=10;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="1720" y="190" width="400" height="120" as="geometry" />
        </mxCell>
