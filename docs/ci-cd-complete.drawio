        <!-- ci-a2a-rag.yml -->
        <mxCell id="wf-ci-rag" value="&lt;b&gt;ci-a2a-rag.yml&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;[CI][A2A] CAIPE RAG Build and Push&lt;br&gt;&lt;br&gt;&lt;b&gt;PR paths:&lt;/b&gt; ai_platform_engineering/knowledge_bases/rag/**&lt;br&gt;&lt;br&gt;Jobs: load-config → determine-changes → build-and-push → retag-unchanged → notify-release&lt;br&gt;&lt;br&gt;Images: &lt;b&gt;matrix from .github/agents.json (.rag_components)&lt;/b&gt;&lt;br&gt;Variants: default, slim (ingestors), huggingface (server)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=SFMono-Regular;fontSize=10;html=1;align=center;" vertex="1" parent="1">
