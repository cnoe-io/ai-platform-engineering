        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- SECTION A: TRIGGERS (left column)                           -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <mxCell id="sec-a-label" value="&lt;b&gt;TRIGGERS&lt;/b&gt;" style="text;html=1;fontSize=14;fontFamily=SFMono-Regular;fontColor=#333;" vertex="1" parent="1">
