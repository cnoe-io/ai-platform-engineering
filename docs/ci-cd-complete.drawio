        <!-- release-finalize.yml -->
        <mxCell id="wf-finalize" value="&lt;b&gt;release-finalize.yml&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;[Release] Finalize Release&lt;br&gt;Trigger: repository_dispatch [ci-completed]&lt;br&gt;&lt;br&gt;Job: &lt;b&gt;check-and-publish&lt;/b&gt;&lt;br&gt;Collects status from 6 required CI workflows.&lt;br&gt;When ALL pass → gh release edit --draft=false&lt;br&gt;Also cleans up old RC tags.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=SFMono-Regular;fontSize=10;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="1720" y="360" width="400" height="120" as="geometry" />
