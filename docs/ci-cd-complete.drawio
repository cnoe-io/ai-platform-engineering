        <!-- Shared action: determine-release-tag (used by all 7 CIs) -->
        <mxCell id="act-determine-release-tag" value="&lt;b&gt;determine-release-tag&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;.github/actions/determine-release-tag/action.yml&lt;br&gt;&lt;br&gt;Priority: tag-push &gt; manual &gt; fallback&lt;br&gt;1. Tag push → github.ref_name&lt;br&gt;2. workflow_dispatch → inputs.manual_tag&lt;br&gt;3. Fallback: poll auto-tag.yml via gh run watch (legacy)&lt;br&gt;&lt;br&gt;Outputs: &lt;b&gt;tag_version&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=SFMono-Regular;fontSize=10;html=1;align=center;" vertex="1" parent="1">
