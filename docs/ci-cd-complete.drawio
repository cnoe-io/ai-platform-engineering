        </mxCell>

        <!-- ci-mcp-sub-agent.yml -->
        <mxCell id="wf-ci-mcp" value="&lt;b&gt;ci-mcp-sub-agent.yml&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;[CI][MCP] Sub-Agents MCP Docker Build and Push&lt;br&gt;&lt;br&gt;&lt;b&gt;PR paths:&lt;/b&gt; ai_platform_engineering/agents/**,&lt;br&gt;build/agents/Dockerfile.mcp&lt;br&gt;&lt;br&gt;Jobs: load-config → determine-agents → build-and-push → retag-unchanged → notify-release&lt;br&gt;&lt;br&gt;Images: &lt;b&gt;matrix from .github/agents.json (.mcp_agents)&lt;/b&gt;&lt;br&gt;&lt;b&gt;dispatch input:&lt;/b&gt; build_all, tag_version&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=SFMono-Regular;fontSize=10;html=1;align=center;" vertex="1" parent="1">
