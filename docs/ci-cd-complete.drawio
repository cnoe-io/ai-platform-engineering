          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="640" y="660" />
              <mxPoint x="640" y="840" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- HELM WORKFLOWS                                              -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <mxCell id="wf-helm" value="&lt;b&gt;helm.yml&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;[CI][Helm] Publish Helm Charts to GHCR&lt;br&gt;&lt;br&gt;Job: &lt;b&gt;publish&lt;/b&gt;&lt;br&gt;Detects changed charts, packages + pushes to GHCR OCI&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=SFMono-Regular;fontSize=10;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="350" y="750" width="260" height="80" as="geometry" />
        </mxCell>
        <mxCell id="e-main-charts-helm" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="trig-push-main-charts" target="wf-helm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="wf-helm-rc" value="&lt;b&gt;release-helm-rc.yml&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;[Release] Helm RC for Release Branches&lt;br&gt;&lt;br&gt;Job: &lt;b&gt;publish-release-helm-rc&lt;/b&gt;&lt;br&gt;Resolves RC version + appVersion from tags,&lt;br&gt;packages changed charts as x.y.z-rc.N&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=SFMono-Regular;fontSize=10;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="350" y="860" width="260" height="100" as="geometry" />
        </mxCell>
        <mxCell id="e-release-charts-helmrc" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.3;" edge="1" parent="1" source="trig-push-release-charts" target="wf-helm-rc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- pr-version-bump.yml -->
        <mxCell id="wf-pr-bump" value="&lt;b&gt;pr-version-bump.yml&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;[CI] PR Version Bump&lt;br&gt;&lt;br&gt;Job 1: &lt;b&gt;version-bump&lt;/b&gt;&lt;br&gt;  → uses: determine-version (action)&lt;br&gt;  → uses: update-version-files (action)&lt;br&gt;&lt;br&gt;Job 2: &lt;b&gt;helm-pre-release&lt;/b&gt;&lt;br&gt;  → calls helm-pre-release.yml (reusable workflow)&lt;br&gt;  (only if prebuild/ branch or helm-prerelease label)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=SFMono-Regular;fontSize=10;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="350" y="990" width="260" height="155" as="geometry" />
        </mxCell>
        <mxCell id="e-pr-version-bump" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.3;" edge="1" parent="1" source="trig-pr-version" target="wf-pr-bump">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- helm-pre-release.yml (reusable) -->
        <mxCell id="wf-helm-prerelease" value="&lt;b&gt;helm-pre-release.yml&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;[Pre-Release] Helm Chart&lt;br&gt;Trigger: &lt;b&gt;workflow_call&lt;/b&gt; only&lt;br&gt;&lt;br&gt;Job: publish-pre-release&lt;br&gt;Packages chart as 0.0.0-pr.N&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=SFMono-Regular;fontSize=10;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="680" y="1020" width="240" height="95" as="geometry" />
        </mxCell>
        <mxCell id="e-bump-helmpr" value="workflow_call" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=1;dashed=1;fontFamily=SFMono-Regular;fontSize=8;exitX=1;exitY=0.7;entryX=0;entryY=0.5;" edge="1" parent="1" source="wf-pr-bump" target="wf-helm-prerelease">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- helm-pre-release-cleanup.yml -->
        <mxCell id="wf-helm-cleanup" value="&lt;b&gt;helm-pre-release-cleanup.yml&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;[Pre-Release] Helm Chart Cleanup&lt;br&gt;Trigger: pull_request [closed, unlabeled] paths: charts/**&lt;br&gt;Job: cleanup-pre-release&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=SFMono-Regular;fontSize=10;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="680" y="1140" width="300" height="65" as="geometry" />
        </mxCell>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- CI DECISION LOGIC (right side detail box)                   -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <mxCell id="ci-logic-box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#999;dashed=1;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="1720" y="580" width="500" height="420" as="geometry" />
        </mxCell>
        <mxCell id="ci-logic-title" value="&lt;b&gt;CI Workflow Internal Logic (shared by all 7 ci-*.yml)&lt;/b&gt;" style="text;html=1;fontSize=12;fontFamily=SFMono-Regular;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="1730" y="585" width="400" height="20" as="geometry" />
        </mxCell>
        <mxCell id="ci-step1" value="&lt;b&gt;1. determine-changes job&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;→ uses: ./.github/actions/determine-release-tag → tag_version&lt;br&gt;→ image_prefix output: tag matches -(rc|hotfix)\\. → &quot;pre-release/&quot; else &quot;&quot;&lt;br&gt;→ chart-only skip: tag ends with -chart.N → skip_build=true&lt;br&gt;→ dorny/paths-filter for per-file change detection&lt;br&gt;→ If N==1 (first tag in series) → force build_all=true&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontFamily=SFMono-Regular;fontSize=10;html=1;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1740" y="615" width="460" height="100" as="geometry" />
        </mxCell>
        <mxCell id="ci-step2" value="&lt;b&gt;2. build-and-push job&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;→ Condition: skip_build != true AND (code changed OR build_all)&lt;br&gt;→ IMAGE_NAME = ghcr.io/cnoe-io/${{ image_prefix }}&amp;lt;name&amp;gt;&lt;br&gt;→ docker/build-push-action with tag_version as image tag&lt;br&gt;→ Platforms: linux/amd64 (+ linux/arm64 for some)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontFamily=SFMono-Regular;fontSize=10;html=1;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1740" y="725" width="460" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ci-step3" value="&lt;b&gt;3. retag-unchanged job&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;→ Condition: tag push AND code NOT changed AND NOT chart-only&lt;br&gt;→ Pulls latest -(dev|rc|hotfix).N image, retags to new version, pushes&lt;br&gt;→ Source tag regex: -(?:dev|rc|hotfix)\\.[0-9]+&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontFamily=SFMono-Regular;fontSize=10;html=1;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1740" y="815" width="460" height="70" as="geometry" />
        </mxCell>
        <mxCell id="ci-step4" value="&lt;b&gt;4. notify-release job&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;→ Condition: tag push AND tag does NOT contain '-' (final release x.y.z only)&lt;br&gt;→ gh api /repos/{owner}/{repo}/dispatches → event_type: ci-completed&lt;br&gt;→ Triggers release-finalize.yml via repository_dispatch&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontFamily=SFMono-Regular;fontSize=10;html=1;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1740" y="895" width="460" height="70" as="geometry" />
        </mxCell>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- TESTING &amp; SUPPORTING WORKFLOWS                              -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <mxCell id="sec-test-label" value="&lt;b&gt;TESTING &amp;amp; SUPPORTING WORKFLOWS&lt;/b&gt;" style="text;html=1;fontSize=12;fontFamily=SFMono-Regular;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="20" y="1130" width="350" height="25" as="geometry" />
        </mxCell>

        <mxCell id="wf-unit-tests" value="&lt;b&gt;tests-unit-tests.yml&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;[Tests] Unit Tests&lt;br&gt;Trigger: push main | PR main&lt;br&gt;Jobs: run-tests, run-argocd-tests&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=SFMono-Regular;fontSize=10;html=1;align=center;" vertex="1" parent="1">
