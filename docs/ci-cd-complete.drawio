        <mxCell id="trig-push-main" value="&lt;b&gt;push → main&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;paths: ai_platform_engineering/**&lt;br&gt;build/** | pyproject.toml | uv.lock | charts/**&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=SFMono-Regular;fontSize=10;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="150" width="230" height="65" as="geometry" />
        </mxCell>

        <mxCell id="trig-push-release" value="&lt;b&gt;push → release/**&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;paths: ai_platform_engineering/**&lt;br&gt;build/** | pyproject.toml | uv.lock | charts/**&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=SFMono-Regular;fontSize=10;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="240" width="230" height="65" as="geometry" />
        </mxCell>

        <mxCell id="trig-tag-push" value="&lt;b&gt;push → tags: '**'&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;Created by auto-tag.yml&lt;br&gt;e.g. 0.3.0-dev.6, 0.3.0-rc.2&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=SFMono-Regular;fontSize=10;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="370" width="230" height="60" as="geometry" />
        </mxCell>

        <mxCell id="trig-pr" value="&lt;b&gt;pull_request&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;(various path filters per CI workflow)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=SFMono-Regular;fontSize=10;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="490" width="230" height="45" as="geometry" />
        </mxCell>

        <mxCell id="trig-manual" value="&lt;b&gt;workflow_dispatch&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;Manual trigger with inputs&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=SFMono-Regular;fontSize=10;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="580" width="230" height="45" as="geometry" />
        </mxCell>

        <mxCell id="trig-push-release-charts" value="&lt;b&gt;push → release/**&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;paths: charts/**&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=SFMono-Regular;fontSize=10;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="680" width="230" height="45" as="geometry" />
        </mxCell>

        <mxCell id="trig-push-main-charts" value="&lt;b&gt;push → main&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;paths: charts/**&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=SFMono-Regular;fontSize=10;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="760" width="230" height="45" as="geometry" />
        </mxCell>

        <mxCell id="trig-pr-version" value="&lt;b&gt;pull_request → main | release/**&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;paths: charts/** | ai_platform_engineering/**&lt;br&gt;build/** | pyproject.toml | uv.lock&lt;br&gt;types: [opened, synchronize]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=SFMono-Regular;fontSize=10;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="850" width="230" height="75" as="geometry" />
        </mxCell>

        <mxCell id="trig-repo-dispatch" value="&lt;b&gt;repository_dispatch&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;types: [ci-completed]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=SFMono-Regular;fontSize=10;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="970" width="230" height="45" as="geometry" />
        </mxCell>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- auto-tag.yml                                                -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <mxCell id="wf-autotag" value="&lt;b&gt;auto-tag.yml&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;[Release] Auto-tag on Push&lt;br&gt;&lt;br&gt;Job: &lt;b&gt;auto-tag&lt;/b&gt;&lt;br&gt;1. determine-version (action)&lt;br&gt;2. update-version-files (action)&lt;br&gt;3. git commit + git tag + git push&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=SFMono-Regular;fontSize=10;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="350" y="170" width="240" height="110" as="geometry" />
        </mxCell>
        <mxCell id="e-main-autotag" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.3;" edge="1" parent="1" source="trig-push-main" target="wf-autotag">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-release-autotag" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.7;" edge="1" parent="1" source="trig-push-release" target="wf-autotag">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ── Actions used by auto-tag ──────────────────────────────── -->
        <mxCell id="act-determine-version" value="&lt;b&gt;determine-version&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;.github/actions/determine-version/action.yml&lt;br&gt;&lt;br&gt;1. Branch detect → base_version + suffix (dev|rc|hotfix)&lt;br&gt;2. Fetch+parse existing tags via GitHub API&lt;br&gt;3. Resolve diff target (tag or merge-base)&lt;br&gt;4. Detect chart-only changes (git diff under charts/ only)&lt;br&gt;5. Compute tag: x.y.z-{dev|rc|hotfix}.N[-chart.M]&lt;br&gt;&lt;br&gt;Outputs: &lt;b&gt;tag&lt;/b&gt;, &lt;b&gt;diff_target&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=SFMono-Regular;fontSize=10;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="310" y="-10" width="320" height="155" as="geometry" />
        </mxCell>
        <mxCell id="e-autotag-detver" value="uses:" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=1;dashed=1;fontFamily=SFMono-Regular;fontSize=9;exitX=0.4;exitY=0;entryX=0.4;entryY=1;" edge="1" parent="1" source="wf-autotag" target="act-determine-version">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="act-update-version" value="&lt;b&gt;update-version-files&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;.github/actions/update-version-files/action.yml&lt;br&gt;&lt;br&gt;No -chart.M → FULL UPDATE:&lt;br&gt;  pyproject.toml, uv.lock, ALL Chart.yaml&lt;br&gt;  (version + appVersion + deps)&lt;br&gt;Has -chart.M → CHART-ONLY:&lt;br&gt;  detect changed charts, cascade to parents&lt;br&gt;&lt;br&gt;Outputs: &lt;b&gt;final_version&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=SFMono-Regular;fontSize=10;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="680" y="-10" width="300" height="155" as="geometry" />
        </mxCell>
        <mxCell id="e-autotag-updver" value="uses:" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=1;dashed=1;fontFamily=SFMono-Regular;fontSize=9;exitX=0.8;exitY=0;entryX=0.5;entryY=1;" edge="1" parent="1" source="wf-autotag" target="act-update-version">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- auto-tag pushes a tag → tag push event -->
        <mxCell id="e-autotag-tagpush" value="git push tag" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d6b656;strokeWidth=2;fontFamily=SFMono-Regular;fontSize=9;fontStyle=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="wf-autotag" target="trig-tag-push">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="470" y="330" />
              <mxPoint x="135" y="330" />
            </Array>
          </mxGeometry>
        </mxCell>

