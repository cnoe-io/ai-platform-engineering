# Example EKS values for installing CAIPE with pre-created Kubernetes Secrets.
#
# Expected Secrets:
#   keycloak-admin-secret   username, password
#   existing-llm-secret       LLM_PROVIDER plus provider API keys/model settings
#   caipe-ui-secret           NEXTAUTH_SECRET, OIDC_CLIENT_SECRET, MONGODB_URI
#   dynamic-agents-secret     MONGODB_URI and any Dynamic Agents sensitive env
#   argocd-secret             ARGOCD_TOKEN, ARGOCD_API_URL
#   github-secret             GITHUB_PERSONAL_ACCESS_TOKEN
#   atlassian-secret          ATLASSIAN_TOKEN, ATLASSIAN_EMAIL, ATLASSIAN_API_URL
#   pagerduty-secret          PAGERDUTY_API_KEY
#   slack-secret              Slack MCP credentials when mcp-slack is enabled

tags:
  caipe-ui: true
  dynamic-agents: true
  keycloak: true
  rag-stack: true
  mcp-argocd: true
  mcp-confluence: true
  mcp-github: true
  mcp-jira: true
  mcp-pagerduty: true
  mcp-slack: false

global:
  createLlmSecret: false
  llmSecrets:
    create: false
    secretName: "existing-llm-secret"
  agentSecrets:
    create: false
  externalSecrets:
    enabled: false
  rag:
    enableGraphRag: true
  agentgateway:
    enabled: true

caipe-ui:
  existingSecret: "caipe-ui-secret"
  mongodb:
    enabled: false
  config:
    NEXTAUTH_URL: "https://caipe-ui.example.com"
    KEYCLOAK_URL: "http://ai-platform-engineering-keycloak:8080"
    KEYCLOAK_REALM: "caipe"
    MONGODB_DATABASE: "caipe"
    OPENFGA_HTTP: "http://ai-platform-engineering-openfga:8080"
    OPENFGA_RECONCILE_ENABLED: "true"
    CAIPE_UNSAFE_RBAC_BYPASS: "false"

dynamic-agents:
  existingSecret: "dynamic-agents-secret"
  llmSecret: "existing-llm-secret"
  config:
    KEYCLOAK_URL: "http://ai-platform-engineering-keycloak:8080"
    OIDC_ISSUER: "https://caipe-ui.example.com/realms/caipe"
    OPENFGA_HTTP: "http://ai-platform-engineering-openfga:8080"
    OPENFGA_STORE_NAME: "caipe-openfga"
    MONGODB_DATABASE: "caipe"
    CAIPE_API_URL: "http://ai-platform-engineering-caipe-ui:3000"

mcp-argocd:
  agentSecrets:
    secretName: "argocd-secret"

mcp-confluence:
  agentSecrets:
    secretName: "atlassian-secret"

mcp-github:
  agentSecrets:
    secretName: "github-secret"

mcp-jira:
  agentSecrets:
    secretName: "atlassian-secret"

mcp-pagerduty:
  agentSecrets:
    secretName: "pagerduty-secret"

mcp-slack:
  agentSecrets:
    secretName: "slack-secret"

rag-stack:
  global:
    llmSecrets:
      create: false
      secretName: "existing-llm-secret"
    rag:
      enableGraphRag: true

keycloak:
  admin:
    secretRef: "keycloak-admin-secret"
  uiClient:
    secretRef: "caipe-ui-secret"
  platformClient:
    secretRef: "caipe-platform-secret"

openfga:
  enabled: true

agentgateway:
  enabled: true
