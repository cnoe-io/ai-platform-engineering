apiVersion: eksctl.io/v1alpha5
kind: ClusterConfig

metadata:
  name: dev-eks-cluster
  region: us-east-2

# EKS Auto Mode manages all node provisioning via the built-in Karpenter controller.
# After creating the cluster, optionally apply the NodePool manifests in
# deploy/eks/nodepools/ to configure right-sized agent and RAG workload tiers.
autoModeConfig:
  enabled: true

addons:
  - name: metrics-server
