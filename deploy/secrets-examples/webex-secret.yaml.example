# Example Kubernetes Secret for the Webex bot integration.
#
# Split:
#   - ConfigMap (Helm `webex-bot.config`): non-sensitive URLs, feature flags, route mode.
#   - This Secret (or ExternalSecrets): tokens, HMAC/link secrets, Keycloak client secrets.
#
# Required when using DB-backed routes (`WEBEX_AGENT_ROUTES_MODE=db_prefer` or `db_only`):
#   MONGODB_URI — connection string (unless injected from a shared cluster Secret).
#
# Required for message ingestion:
#   WEBEX_INTEGRATION_BOT_ACCESS_TOKEN — from the Webex developer portal (never commit real values).
#
# Optional:
#   WEBEX_WEBHOOK_SECRET, WEBEX_LINK_HMAC_SECRET
#   KEYCLOAK_WEBEX_BOT_CLIENT_SECRET — prefer Keycloak chart Secret `*-keycloak-webex-bot`
#     key `KC_WEBEX_BOT_CLIENT_SECRET` via `webex-bot.keycloakBot.clientSecretFromSecret`.
#   KEYCLOAK_WEBEX_BOT_ADMIN_CLIENT_SECRET — admin API user lookup (often caipe-platform).
#
apiVersion: v1
kind: Secret
metadata:
  name: webex-bot-secrets
  namespace: ai-platform-engineering
type: Opaque
stringData:
  WEBEX_INTEGRATION_BOT_ACCESS_TOKEN: ""
  WEBEX_WEBHOOK_SECRET: ""
  WEBEX_LINK_HMAC_SECRET: ""
  # Required for db_prefer / db_only route modes when not set elsewhere.
  MONGODB_URI: ""
  # Only if not using Keycloak chart single-source-of-truth wiring:
  KEYCLOAK_WEBEX_BOT_CLIENT_SECRET: ""
  KEYCLOAK_WEBEX_BOT_ADMIN_CLIENT_SECRET: ""
