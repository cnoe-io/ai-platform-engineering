# Agent Gateway configuration template for ext_authz-only deployments.
# AgentGateway authorization is delegated to OpenFGA through ext_authz; this
# template intentionally does not render CEL mcpAuthorization rules.
# Template: deploy/agentgateway/config.yaml.j2
# Generation: {{ generation }}
#
# ReBAC migration boundary:
# - jwtAuth authenticates the caller.
# - extAuthz asks the OpenFGA bridge for the authorization decision.
# - AgentGateway does not maintain or proxy CEL authorization policies.

binds:
- port: 4000
  listeners:
  - protocol: HTTP
    policies:
      jwtAuth:
        mode: strict
        issuer: {{ issuer }}
        audiences: [{{ audience }}]
        jwks:
          url: {{ jwks_url }}
    routes:
    - policies:
        extAuthz:
          host: openfga-authz-bridge:9100
          failureMode:
            denyWithStatus: 403
          protocol:
            grpc:
              metadata:
                caipe.auth: '{"sub": jwt.sub}'
        authorization:
          rules:
          - deny: '!has(jwt.sub)'
          - deny: 'has(jwt.org) && has(request.headers.x_tenant_id) && jwt.org != request.headers.x_tenant_id'
          - allow: 'has(jwt.sub)'
      backends:
      -
        mcp:
          targets:
          {% for backend in backends %}
          {% if backend.enabled %}
          - name: {{ backend.id }}
            mcp:
              host: {{ backend.upstream_url }}
          {% endif %}
          {% endfor %}

config:
  adminAddr: 0.0.0.0:15000
  logging:
    level: info
    format: json
